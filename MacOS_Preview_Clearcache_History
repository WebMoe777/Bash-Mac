#!/bin/bash

echo "Closing Preview..."
osascript -e 'quit app "Preview"'

# Remove recent documents list from Preview
echo "Clearing Preview recent documents..."
defaults delete com.apple.Preview "NSRecentDocuments" 2>/dev/null

# Remove QuickLook thumbnail cache
echo "Removing QuickLook thumbnail cache..."
qlmanage -r cache

# Optional: Remove Preview's saved state
echo "Removing Preview saved state..."
rm -rf ~/Library/Saved\ Application\ State/com.apple.Preview.savedState

# Optional: Reset all Preview preferences (uncomment to use)
# echo "Resetting all Preview preferences..."
# defaults delete com.apple.Preview

echo "Preview cache and history cleared."
