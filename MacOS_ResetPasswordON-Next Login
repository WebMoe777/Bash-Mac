#!/bin/bash

# Track users
standard_users=()

echo "Scanning local standard user accounts..."

# Loop through users with UID ≥ 501 (No Admin User)
while IFS= read -r user; do
    # Check if user is NOT an admin
    if ! dseditgroup -o checkmember -m "$user" admin | grep -q "yes"; then
        echo "Forcing password reset for: $user"
        
        # Clear existing pwpolicy and force expiration
        sudo pwpolicy -u "$user" -clearaccountpolicies 2>/dev/null
        sudo dscl . -create /Users/"$user" PasswordPolicy "policyAttributePasswordExpires=1" 2>/dev/null

        standard_users+=("$user")
    fi
done < <(dscl . list /Users UniqueID | awk '$2 >= 501 { print $1 }')

# Report
echo ""
echo "Password reset enforced at next login for the following users:"
for u in "${standard_users[@]}"; do
    echo " - $u"
done
